<Window x:Class="AnimeTranscoder.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:model="clr-namespace:AnimeTranscoder.Models;assembly=AnimeTranscoder.Core"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="番剧一键转码器"
        Width="1380"
        Height="920"
        MinWidth="1100"
        MinHeight="760"
        Background="#F4EFE6"
        FontFamily="Microsoft YaHei UI"
        AllowDrop="True"
        DragEnter="Window_DragEnter"
        DragLeave="Window_DragLeave"
        DragOver="Window_DragOver"
        Drop="Window_Drop">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <SolidColorBrush x:Key="PageBackgroundBrush" Color="#F4EFE6" />
        <SolidColorBrush x:Key="PanelBrush" Color="#FFF9F0" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#D9CBB5" />
        <SolidColorBrush x:Key="AccentBrush" Color="#A54E2B" />
        <SolidColorBrush x:Key="AccentBrushDark" Color="#7A3218" />
        <SolidColorBrush x:Key="InkBrush" Color="#2B241F" />
        <SolidColorBrush x:Key="MutedBrush" Color="#7D6E62" />
        <LinearGradientBrush x:Key="HeroBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Offset="0" Color="#1E2D3B" />
            <GradientStop Offset="0.55" Color="#A54E2B" />
            <GradientStop Offset="1" Color="#E6B36C" />
        </LinearGradientBrush>

        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Border Background="{StaticResource PanelBrush}"
                                BorderBrush="{StaticResource PanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="14">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top"
                                           Margin="0,0,0,12"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource InkBrush}"
                                           Text="{TemplateBinding Header}" />
                                <ContentPresenter />
                            </DockPanel>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrushDark}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="GhostButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#F7E7D6" />
            <Setter Property="Foreground" Value="{StaticResource AccentBrushDark}" />
            <Setter Property="BorderBrush" Value="#D5B79C" />
        </Style>

        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="Margin" Value="0,0,12,0" />
            <Setter Property="Background" Value="#FFF8EE" />
            <Setter Property="BorderBrush" Value="#E0D1BE" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#FFFDFC" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#FFFDFC" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
        </Style>

        <!-- 左侧导航按钮样式 -->
        <Style x:Key="NavButtonStyle" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" Background="Transparent" Padding="16,12" Margin="0,2">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1AFFFFFF" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#33FFFFFF" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter Property="Foreground" Value="#BAA396" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 顶部精简标题栏 -->
        <Border Grid.Row="0" Padding="16,10" Background="{StaticResource HeroBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" FontSize="20" FontWeight="Bold" Foreground="White"
                           VerticalAlignment="Center" Text="番剧一键转码器" />
                <StackPanel Grid.Column="1" Margin="24,0,0,0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Foreground="#FFE7C7" FontSize="12" Text="{Binding HardwareSummary}" />
                    <TextBlock Margin="16,0,0,0" Foreground="#FFF0D2" FontSize="12" Text="{Binding NativeCoreSummary}" />
                    <TextBlock Margin="16,0,0,0" Foreground="#FFE9BF" FontSize="12" Text="{Binding WatchSummary}" />
                </StackPanel>
                <Border Grid.Column="2" Padding="10,4" Background="#26FFF7EB" CornerRadius="8">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Foreground="#FFF7E7" FontSize="12" VerticalAlignment="Center"
                                   Text="当前模式：" />
                        <TextBlock Foreground="White" FontSize="12" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Text="串行转码" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- 主体：左导航 + 右内容 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- 左导航 -->
            <Border Grid.Column="0" Background="#2C1F14" BorderBrush="#4A3020" BorderThickness="0,0,1,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Margin="16,16,16,8" Foreground="#8A7060"
                               FontSize="11" FontWeight="Bold" Text="功能模块" />
                    <StackPanel Margin="0,0,0,0">

                        <RadioButton x:Name="NavTaskQueue" GroupName="NavGroup" IsChecked="True"
                                     Style="{StaticResource NavButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📋" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBlock Text="任务队列" VerticalAlignment="Center" />
                            </StackPanel>
                        </RadioButton>

                        <RadioButton x:Name="NavAudio" GroupName="NavGroup"
                                     Style="{StaticResource NavButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🎤" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBlock Text="音频工坊" VerticalAlignment="Center" />
                            </StackPanel>
                        </RadioButton>

                        <RadioButton x:Name="NavClip" GroupName="NavGroup"
                                     Style="{StaticResource NavButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="✂️" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBlock Text="视频裁剪" VerticalAlignment="Center" />
                            </StackPanel>
                        </RadioButton>

                        <RadioButton x:Name="NavDouyin" GroupName="NavGroup"
                                     Style="{StaticResource NavButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📱" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBlock Text="抖音直出" VerticalAlignment="Center" />
                            </StackPanel>
                        </RadioButton>

                        <RadioButton x:Name="NavHistory" GroupName="NavGroup"
                                     Style="{StaticResource NavButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📜" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBlock Text="任务历史" VerticalAlignment="Center" />
                            </StackPanel>
                        </RadioButton>

                        <RadioButton x:Name="NavInspection" GroupName="NavGroup"
                                     Style="{StaticResource NavButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔍" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBlock Text="巡检截图" VerticalAlignment="Center" />
                            </StackPanel>
                        </RadioButton>

                        <RadioButton x:Name="NavLog" GroupName="NavGroup"
                                     Style="{StaticResource NavButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📄" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBlock Text="运行日志" VerticalAlignment="Center" />
                            </StackPanel>
                        </RadioButton>

                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- 右侧内容区 -->
            <Grid Grid.Column="1">

                <!-- 任务队列模块 -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                              Padding="18"
                              Visibility="{Binding IsChecked, ElementName=NavTaskQueue, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel>

                        <!-- 目录与扫描 -->
                        <GroupBox Header="📂 目录与扫描" Margin="0,0,0,16">
                            <Grid Margin="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="输入目录" />
                                <TextBox Grid.Row="0" Grid.Column="1" Margin="8,0,8,8" Text="{Binding Settings.InputDirectory, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Grid.Row="0" Grid.Column="2" Padding="12,6" Margin="0,0,0,8" Command="{Binding ChooseInputDirectoryCommand}" Content="浏览" />
                                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="输出目录" />
                                <TextBox Grid.Row="1" Grid.Column="1" Margin="8,0,8,8" Text="{Binding Settings.OutputDirectory, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Grid.Row="1" Grid.Column="2" Padding="12,6" Margin="0,0,0,8" Command="{Binding ChooseOutputDirectoryCommand}" Content="浏览" />
                                <StackPanel Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal">
                                    <Button Command="{Binding ScanInputDirectoryCommand}" Content="扫描输入目录" />
                                    <Button Command="{Binding OpenOutputDirectoryCommand}" Content="打开输出目录" />
                                    <Button Margin="0" Command="{Binding SaveSettingsCommand}" Content="保存设置" />
                                </StackPanel>
                            </Grid>
                        </GroupBox>

                        <!-- 转换参数 -->
                        <GroupBox Header="⚙️ 转换参数" Margin="0,0,0,16">
                            <Grid Margin="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="字幕偏好" />
                                <ComboBox Grid.Row="0" Grid.Column="1" Margin="8,0,16,8"
                                          SelectedValue="{Binding Settings.SubtitlePreference}"
                                          SelectedValuePath="Tag">
                                    <ComboBoxItem Tag="chs">简体中文优先</ComboBoxItem>
                                    <ComboBoxItem Tag="cht">繁体中文优先</ComboBoxItem>
                                    <ComboBoxItem Tag="default">使用默认字幕轨</ComboBoxItem>
                                </ComboBox>
                                <TextBlock Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" Text="编码模式" />
                                <ComboBox Grid.Row="0" Grid.Column="2" Margin="100,0,0,8"
                                          SelectedValue="{Binding Settings.VideoEncoderMode}"
                                          SelectedValuePath="Tag">
                                    <ComboBoxItem Tag="auto">自动选择</ComboBoxItem>
                                    <ComboBoxItem Tag="h264_nvenc">GPU 加速（NVENC）</ComboBoxItem>
                                    <ComboBoxItem Tag="libx264">CPU 编码（libx264）</ComboBoxItem>
                                </ComboBox>
                                <CheckBox Grid.Row="1" Grid.Column="1" Margin="8,0,16,8"
                                          IsChecked="{Binding Settings.OverwriteExisting}"
                                          Content="覆盖已存在的输出文件" />
                                <CheckBox Grid.Row="1" Grid.Column="2"
                                          IsChecked="{Binding Settings.DeleteSourceAfterSuccess}"
                                          Content="转换完成后删除源文件" />
                                <CheckBox Grid.Row="2" Grid.Column="1" Margin="8,0,16,8"
                                          IsChecked="{Binding Settings.EnableDirectoryWatch}"
                                          Content="自动监听输入目录并检测稳定文件" />
                                <StackPanel Grid.Row="2" Grid.Column="2" Orientation="Horizontal">
                                    <TextBlock Margin="0,2,10,0" VerticalAlignment="Center" Text="稳定等待" />
                                    <ComboBox Width="120"
                                              SelectedValue="{Binding Settings.StableFileWaitSeconds}"
                                              SelectedValuePath="Tag">
                                        <ComboBoxItem><ComboBoxItem.Tag><sys:Int32>10</sys:Int32></ComboBoxItem.Tag>10 秒</ComboBoxItem>
                                        <ComboBoxItem><ComboBoxItem.Tag><sys:Int32>20</sys:Int32></ComboBoxItem.Tag>20 秒</ComboBoxItem>
                                        <ComboBoxItem><ComboBoxItem.Tag><sys:Int32>30</sys:Int32></ComboBoxItem.Tag>30 秒</ComboBoxItem>
                                        <ComboBoxItem><ComboBoxItem.Tag><sys:Int32>60</sys:Int32></ComboBoxItem.Tag>60 秒</ComboBoxItem>
                                    </ComboBox>
                                </StackPanel>
                                <CheckBox Grid.Row="3" Grid.Column="1" Margin="8,0,16,8"
                                          IsChecked="{Binding Settings.AutoStartQueueOnWatch}"
                                          Content="监听到稳定文件后自动开始队列" />
                                <TextBlock Grid.Row="3" Grid.Column="2" VerticalAlignment="Center"
                                           Foreground="{StaticResource MutedBrush}"
                                           Text="开启后，新文件稳定后会自动入队并直接开跑" />
                                <StackPanel Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal">
                                    <Button Command="{Binding AddFilesCommand}" Content="添加文件" />
                                    <Button Command="{Binding AddFolderCommand}" Content="添加文件夹" />
                                    <Button Command="{Binding StartQueueCommand}" Content="开始转码" />
                                    <Button Command="{Binding CancelCommand}" Content="取消当前任务" />
                                    <Button Style="{StaticResource GhostButtonStyle}" Command="{Binding RetryFailedJobsCommand}" Content="重试失败项" />
                                    <Button Style="{StaticResource GhostButtonStyle}" Command="{Binding ClearFinishedJobsCommand}" Content="清理已结束项" />
                                    <Button Margin="0" Command="{Binding RemoveSelectedCommand}" Content="移除选中项" />
                                </StackPanel>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="🛰️ 弹幕配置" Margin="0,0,0,16">
                            <Grid Margin="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="130" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <CheckBox Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,16,8"
                                          IsChecked="{Binding Settings.BurnEmbeddedSubtitles}"
                                          Content="同时烧录内嵌字幕" />
                                <CheckBox Grid.Row="0" Grid.Column="2" Grid.ColumnSpan="2" Margin="0,0,0,8"
                                          IsChecked="{Binding Settings.EnableDanmaku}"
                                          Content="启用弹幕叠加" />

                                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="弹幕来源" />
                                <ComboBox Grid.Row="1" Grid.Column="1" Margin="8,0,16,8"
                                          SelectedValue="{Binding Settings.DanmakuSourceMode}"
                                          SelectedValuePath="Tag">
                                    <ComboBoxItem Tag="bilibili_auto">Bilibili 自动获取</ComboBoxItem>
                                    <ComboBoxItem Tag="local_file">任务绑定本地文件</ComboBoxItem>
                                </ComboBox>
                                <TextBlock Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" Text="映射配置" />
                                <TextBox Grid.Row="1" Grid.Column="3" Margin="8,0,0,8"
                                         Text="{Binding Settings.DanmakuMappingPath, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="显示区域" />
                                <ComboBox Grid.Row="2" Grid.Column="1" Margin="8,0,16,8"
                                          SelectedValue="{Binding Settings.DanmakuAreaMode}"
                                          SelectedValuePath="Tag">
                                    <ComboBoxItem Tag="full_screen">全屏铺开</ComboBoxItem>
                                    <ComboBoxItem Tag="upper_half">仅上半屏</ComboBoxItem>
                                </ComboBox>
                                <TextBlock Grid.Row="2" Grid.Column="2" VerticalAlignment="Center" Text="字体名称" />
                                <TextBox Grid.Row="2" Grid.Column="3" Margin="8,0,0,8"
                                         Text="{Binding Settings.DanmakuFontName, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="字号" />
                                <TextBox Grid.Row="3" Grid.Column="1" Margin="8,0,16,8"
                                         Text="{Binding Settings.DanmakuFontSize, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Grid.Row="3" Grid.Column="2" VerticalAlignment="Center" Text="密度" />
                                <TextBox Grid.Row="3" Grid.Column="3" Margin="8,0,0,8"
                                         Text="{Binding Settings.DanmakuDensity, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Text="时间偏移(秒)" />
                                <TextBox Grid.Row="4" Grid.Column="1" Margin="8,0,16,8"
                                         Text="{Binding Settings.DanmakuTimeOffsetSeconds, UpdateSourceTrigger=PropertyChanged}" />
                                <CheckBox Grid.Row="4" Grid.Column="2" Grid.ColumnSpan="2" Margin="8,0,0,8"
                                          IsChecked="{Binding Settings.DanmakuFilterSpecialTypes}"
                                          Content="过滤特殊弹幕（mode 7/8）" />

                                <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,4,0,0" VerticalAlignment="Top" Text="屏蔽词" />
                                <TextBox Grid.Row="5" Grid.Column="1" Margin="8,0,16,0" Height="68"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         Text="{Binding Settings.DanmakuBlockKeywords, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Grid.Row="5" Grid.Column="2" Grid.ColumnSpan="2" Margin="8,4,0,0"
                                           Foreground="{StaticResource MutedBrush}"
                                           Text="本地文件模式下，请在下方“选中任务详情”里给每个任务单独绑定 XML/ASS。" 
                                           TextWrapping="Wrap" />
                            </Grid>
                        </GroupBox>

                        <!-- 统计卡片 + 拖拽投放区 -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="3*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <Border Style="{StaticResource StatCardStyle}">
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource MutedBrush}" Text="总任务数" />
                                        <TextBlock Margin="0,8,0,0" FontSize="28" FontWeight="Bold"
                                                   Foreground="{StaticResource InkBrush}" Text="{Binding TotalJobs}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource StatCardStyle}">
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource MutedBrush}" Text="等待中" />
                                        <TextBlock Margin="0,8,0,0" FontSize="28" FontWeight="Bold"
                                                   Foreground="#B36A24" Text="{Binding PendingJobs}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource StatCardStyle}">
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource MutedBrush}" Text="已完成" />
                                        <TextBlock Margin="0,8,0,0" FontSize="28" FontWeight="Bold"
                                                   Foreground="#2D7B52" Text="{Binding SuccessJobs}" />
                                    </StackPanel>
                                </Border>
                                <Border Margin="0" Style="{StaticResource StatCardStyle}">
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource MutedBrush}" Text="失败数" />
                                        <TextBlock Margin="0,8,0,0" FontSize="28" FontWeight="Bold"
                                                   Foreground="#B54A3B" Text="{Binding FailedJobs}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                            <Border Grid.Column="1" Margin="12,0,0,0" Padding="18" Background="#FFF7EC"
                                    BorderBrush="#D7C5AF" BorderThickness="2" CornerRadius="16">
                                <StackPanel>
                                    <TextBlock FontSize="16" FontWeight="Bold"
                                               Foreground="{StaticResource InkBrush}" Text="拖拽投放区" />
                                    <TextBlock Margin="0,6,0,0" Foreground="{StaticResource MutedBrush}"
                                               Text="把 MKV 文件或包含 MKV 的文件夹直接拖进这个窗口。"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,8,0,0" Foreground="{StaticResource AccentBrushDark}"
                                               Text="{Binding QueueSummary}" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- 任务列表 -->
                        <GroupBox Header="任务队列列表" Margin="0,0,0,16">
                            <DataGrid Height="220" Margin="0"
                                      AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                      RowBackground="#FFFDF8" AlternatingRowBackground="#FFF6EB"
                                      BorderThickness="0" SelectionMode="Single"
                                      ItemsSource="{Binding Jobs}"
                                      SelectedItem="{Binding SelectedJob}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Width="2*" Header="文件名" Binding="{Binding FileName}" />
                                    <DataGridTemplateColumn Width="*" Header="状态">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border Padding="8,4" CornerRadius="10">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#EAD9C6" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="{x:Static model:JobStatus.Pending}"><Setter Property="Background" Value="#F4DFC7" /></DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="{x:Static model:JobStatus.Probing}"><Setter Property="Background" Value="#E8DCCB" /></DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="{x:Static model:JobStatus.Running}"><Setter Property="Background" Value="#DDE6F8" /></DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="{x:Static model:JobStatus.Success}"><Setter Property="Background" Value="#DCEEDF" /></DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="{x:Static model:JobStatus.Failed}"><Setter Property="Background" Value="#F5D9D5" /></DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="{x:Static model:JobStatus.Skipped}"><Setter Property="Background" Value="#E7E1DA" /></DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="{x:Static model:JobStatus.Cancelled}"><Setter Property="Background" Value="#E5DBD8" /></DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock HorizontalAlignment="Center" Foreground="{StaticResource InkBrush}" FontWeight="SemiBold" Text="{Binding StatusText}" />
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Width="*" Header="字幕序号" Binding="{Binding SubtitleStreamOrdinal}" />
                                    <DataGridTextColumn Width="*" Header="编码器" Binding="{Binding EncoderUsed}" />
                                    <DataGridTextColumn Width="*" Header="速度" Binding="{Binding Speed}" />
                                    <DataGridTemplateColumn Width="1.4*" Header="进度">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,4">
                                                    <ProgressBar Height="18" Minimum="0" Maximum="100"
                                                                 Value="{Binding Progress}"
                                                                 Foreground="{StaticResource AccentBrush}" Background="#E8DDD0" />
                                                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               FontSize="11" FontWeight="SemiBold"
                                                               Foreground="{StaticResource InkBrush}"
                                                               Text="{Binding Progress, StringFormat={}{0:F0}%}" />
                                                </Grid>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Width="1.6*" Header="字幕类型" Binding="{Binding SubtitleKindSummary}" />
                                    <DataGridTextColumn Width="2*" Header="说明" Binding="{Binding Message}" />
                                    <DataGridTextColumn Width="2*" Header="输出文件" Binding="{Binding OutputPath}" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </GroupBox>

                        <!-- 选中任务详情 -->
                        <GroupBox Header="选中任务详情" Margin="0,0,0,16">
                            <Grid Margin="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.2*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock FontSize="16" FontWeight="Bold" Foreground="{StaticResource InkBrush}" Text="{Binding SelectedJobTitle}" />
                                    <TextBlock Margin="0,4,0,0" Foreground="{StaticResource AccentBrushDark}" Text="{Binding SelectedJobStatusText}" />
                                    <Border Margin="0,8,0,0" Padding="10" Background="#FFF0DD" BorderBrush="#E1D1BE" BorderThickness="1" CornerRadius="10">
                                        <TextBlock Foreground="{StaticResource InkBrush}" Text="{Binding SelectedJobMessage}" TextWrapping="Wrap" />
                                    </Border>
                                    <Border Margin="0,12,0,0" Padding="10" Background="#FFF8EE" BorderBrush="#E1D1BE" BorderThickness="1" CornerRadius="12">
                                        <StackPanel>
                                            <DockPanel LastChildFill="False">
                                                <TextBlock DockPanel.Dock="Left" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}" Text="叠加预览" />
                                                <TextBlock Margin="12,0,0,0" Foreground="{StaticResource MutedBrush}" Text="{Binding SelectedPreviewSummary}" TextWrapping="Wrap" />
                                            </DockPanel>
                                            <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                                                <TextBlock VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" Text="时间点(秒)" />
                                                <TextBox Width="90" Margin="8,0,12,0"
                                                         Text="{Binding SelectedPreviewTimeText, UpdateSourceTrigger=PropertyChanged}" />
                                                <Button Command="{Binding RefreshSelectedPreviewCommand}" Content="刷新预览" />
                                            </StackPanel>
                                            <Border Margin="0,10,0,0" Height="240" Background="#F3E8D9" BorderBrush="#DCCAB7" BorderThickness="1" CornerRadius="10">
                                                <Image Source="{Binding SelectedPreviewImagePath}" Stretch="Uniform" />
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                    <Border Margin="0,12,0,0" Padding="10" Background="#FFF9F2" BorderBrush="#E1D1BE" BorderThickness="1" CornerRadius="12">
                                        <StackPanel>
                                            <DockPanel LastChildFill="False">
                                                <TextBlock DockPanel.Dock="Left" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}" Text="弹幕编辑台" />
                                                <TextBlock Margin="12,0,0,0" Foreground="{StaticResource MutedBrush}" Text="{Binding SelectedDanmakuAnalysisSummary}" TextWrapping="Wrap" />
                                            </DockPanel>
                                            <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                                                <TextBlock VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" Text="搜索" />
                                                <TextBox Width="180" Margin="8,0,12,0"
                                                         Text="{Binding DanmakuSearchText, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBlock VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" Text="模式" />
                                                <ComboBox Width="110" Margin="8,0,12,0"
                                                          SelectedValue="{Binding SelectedDanmakuModeFilter}"
                                                          SelectedValuePath="Tag">
                                                    <ComboBoxItem Tag="all">全部</ComboBoxItem>
                                                    <ComboBoxItem Tag="scroll">滚动</ComboBoxItem>
                                                    <ComboBoxItem Tag="top">顶部</ComboBoxItem>
                                                    <ComboBoxItem Tag="bottom">底部</ComboBoxItem>
                                                </ComboBox>
                                                <Button Command="{Binding AnalyzeSelectedDanmakuCommand}" Content="重新分析弹幕" />
                                                <Button Command="{Binding OpenGeneratedDanmakuAssCommand}" Content="打开生成 ASS" />
                                                <Button Command="{Binding ClearSelectedDanmakuExclusionsCommand}" Content="清空手动禁用" />
                                                <Button Command="{Binding ImportSelectedDanmakuRulesCommand}" Content="导入规则" />
                                                <Button Command="{Binding ExportSelectedDanmakuRulesCommand}" Content="导出规则" />
                                            </StackPanel>
                                            <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                                                <TextBlock VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" Text="关键词" />
                                                <TextBox Width="260" Margin="8,0,12,0"
                                                         Text="{Binding DanmakuKeywordBatchText, UpdateSourceTrigger=PropertyChanged}" />
                                                <Button Command="{Binding DisableDanmakuByKeywordsCommand}" Content="禁用命中关键词" />
                                                <Button Command="{Binding EnableDanmakuByKeywordsCommand}" Content="恢复命中关键词" />
                                            </StackPanel>
                                            <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                                                <Button Command="{Binding DisableFilteredDanmakuCommand}" Content="禁用当前筛选结果" />
                                                <Button Command="{Binding EnableFilteredDanmakuCommand}" Content="恢复当前筛选结果" />
                                                <TextBlock Margin="12,6,0,0" Foreground="{StaticResource MutedBrush}"
                                                           Text="{Binding FilteredDanmakuCountSummary}" />
                                                <TextBlock Margin="12,6,0,0" Foreground="{StaticResource MutedBrush}"
                                                           Text="{Binding SelectedDanmakuDisabledCount, StringFormat=已手动禁用 {0} 条}" />
                                            </StackPanel>
                                            <DataGrid Margin="0,10,0,0"
                                                      AutoGenerateColumns="False"
                                                      CanUserAddRows="False"
                                                      IsReadOnly="False"
                                                      HeadersVisibility="Column"
                                                      GridLinesVisibility="Horizontal"
                                                      RowBackground="#FFFDF8"
                                                      AlternatingRowBackground="#FFF6EB"
                                                      BorderThickness="0"
                                                      Height="320"
                                                      ItemsSource="{Binding EditableSelectedDanmakuCommentsView}">
                                                <DataGrid.Columns>
                                                    <DataGridCheckBoxColumn Width="68" Header="启用" Binding="{Binding IsEnabled, UpdateSourceTrigger=PropertyChanged}" />
                                                    <DataGridTextColumn Width="84" Header="时间" Binding="{Binding TimeSeconds, StringFormat={}{0:0.###}s}" />
                                                    <DataGridTextColumn Width="66" Header="模式" Binding="{Binding Mode}" />
                                                    <DataGridTextColumn Width="*" Header="内容" Binding="{Binding Content}" />
                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                                <Grid Grid.Column="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="92" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,8,6" Foreground="{StaticResource MutedBrush}" Text="输入" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" Margin="0,0,0,6" Text="{Binding SelectedJobInputPath}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,8,6" Foreground="{StaticResource MutedBrush}" Text="输出" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,0,0,6" Text="{Binding SelectedJobOutputPath}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,8,6" Foreground="{StaticResource MutedBrush}" Text="进度" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,0,0,6" Text="{Binding SelectedJobProgressText}" />
                                    <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,8,6" Foreground="{StaticResource MutedBrush}" Text="编码器" />
                                    <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,0,0,6" Text="{Binding SelectedJobEncoder}" />
                                    <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,0,8,6" Foreground="{StaticResource MutedBrush}" Text="字幕分析" />
                                    <TextBlock Grid.Row="4" Grid.Column="1" Margin="0,0,0,6" Text="{Binding SelectedJobSubtitleAnalysis}" />
                                    <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,0,8,6" Foreground="{StaticResource MutedBrush}" Text="字幕类型" />
                                    <TextBlock Grid.Row="5" Grid.Column="1" Margin="0,0,0,6" Text="{Binding SelectedJobSubtitleKind}" TextWrapping="Wrap" />
                                    <TextBlock Grid.Row="6" Grid.Column="0" Margin="0,0,8,6" Foreground="{StaticResource MutedBrush}" Text="弹幕来源" />
                                    <TextBlock Grid.Row="6" Grid.Column="1" Margin="0,0,0,6" Text="{Binding SelectedJobDanmakuSource}" TextWrapping="Wrap" />
                                    <TextBlock Grid.Row="7" Grid.Column="0" Margin="0,0,8,6" Foreground="{StaticResource MutedBrush}" Text="本地弹幕" />
                                    <TextBlock Grid.Row="7" Grid.Column="1" Margin="0,0,0,6" Text="{Binding SelectedJobDanmakuInputPath}" TextWrapping="Wrap" />
                                    <TextBlock Grid.Row="8" Grid.Column="0" Margin="0,0,8,6" Foreground="{StaticResource MutedBrush}" Text="分析摘要" />
                                    <TextBlock Grid.Row="8" Grid.Column="1" Margin="0,0,0,6" Text="{Binding SelectedJobDanmakuPreparation}" TextWrapping="Wrap" />
                                    <TextBlock Grid.Row="9" Grid.Column="0" Margin="0,0,8,6" Foreground="{StaticResource MutedBrush}" Text="过滤结果" />
                                    <TextBlock Grid.Row="9" Grid.Column="1" Margin="0,0,0,6" Text="{Binding SelectedJobDanmakuXmlStats}" TextWrapping="Wrap" />
                                    <TextBlock Grid.Row="10" Grid.Column="0" Margin="0,0,8,6" Foreground="{StaticResource MutedBrush}" Text="生成 ASS" />
                                    <TextBlock Grid.Row="10" Grid.Column="1" Margin="0,0,0,6" Text="{Binding SelectedJobDanmakuAssPath}" TextWrapping="Wrap" />
                                    <TextBlock Grid.Row="11" Grid.Column="0" Margin="0,0,8,6" Foreground="{StaticResource MutedBrush}" Text="手动禁用" />
                                    <TextBlock Grid.Row="11" Grid.Column="1" Margin="0,0,0,6" Text="{Binding SelectedDanmakuDisabledCount, StringFormat={}{0} 条}" TextWrapping="Wrap" />
                                    <StackPanel Grid.Row="12" Grid.ColumnSpan="2" Margin="0,8,0,0" Orientation="Horizontal">
                                        <Button Command="{Binding ChooseSelectedJobDanmakuCommand}" Content="绑定本地弹幕" />
                                        <Button Command="{Binding ClearSelectedJobDanmakuCommand}" Content="清空绑定" />
                                        <Button Command="{Binding OpenSelectedDanmakuCommand}" Content="打开弹幕文件" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="13" Grid.ColumnSpan="2" Margin="0,8,0,0" Orientation="Horizontal">
                                        <Button Command="{Binding CaptureSelectedFrameSetCommand}" Content="导出巡检三连图" />
                                        <Button Command="{Binding CaptureSelectedFrameCommand}" Content="导出诊断截图" />
                                        <Button Command="{Binding OpenSelectedOutputDirectoryCommand}" Content="打开输出目录" />
                                        <Button Margin="0" Style="{StaticResource GhostButtonStyle}" Command="{Binding OpenLogDirectoryCommand}" Content="打开日志目录" />
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </GroupBox>

                    </StackPanel>
                </ScrollViewer>

                <!-- 音频工坊模块 -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                              Padding="18"
                              Visibility="{Binding IsChecked, ElementName=NavAudio, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <GroupBox Header="音频源">
                            <Grid Margin="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           VerticalAlignment="Center"
                                           Text="输入文件" />
                                <TextBox Grid.Row="0"
                                         Grid.Column="1"
                                         Margin="8,0,8,8"
                                         IsReadOnly="True"
                                         Text="{Binding AudioInputPath, Mode=OneWay}" />
                                <Button Grid.Row="0"
                                        Grid.Column="2"
                                        Padding="12,6"
                                        Margin="0,0,8,8"
                                        Command="{Binding ChooseAudioInputCommand}"
                                        Content="选择媒体" />
                                <Button Grid.Row="0"
                                        Grid.Column="3"
                                        Padding="12,6"
                                        Margin="0,0,0,8"
                                        Style="{StaticResource GhostButtonStyle}"
                                        Command="{Binding UseSelectedJobAsAudioInputCommand}"
                                        Content="带入选中任务" />

                                <TextBlock Grid.Row="1"
                                           Grid.Column="0"
                                           Margin="0,0,0,8"
                                           VerticalAlignment="Center"
                                           Text="输出位置" />
                                <TextBox Grid.Row="1"
                                         Grid.Column="1"
                                         Grid.ColumnSpan="3"
                                         Margin="8,0,0,8"
                                         IsReadOnly="True"
                                         Text="{Binding AudioOutputPathPreview, Mode=OneWay}" />

                                <StackPanel Grid.Row="2"
                                            Grid.Column="1"
                                            Grid.ColumnSpan="3">
                                    <TextBlock Foreground="{StaticResource AccentBrushDark}"
                                               Text="{Binding AudioProbeSummary}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Foreground="{StaticResource MutedBrush}"
                                               Text="{Binding AudioStatusMessage}" />
                                </StackPanel>
                            </Grid>
                        </GroupBox>

                        <GroupBox Grid.Row="1"
                                  Margin="0,14,0,0"
                                  Header="音频项目">
                            <Grid Margin="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           VerticalAlignment="Center"
                                           Text="项目文件" />
                                <TextBox Grid.Row="0"
                                         Grid.Column="1"
                                         Margin="8,0,8,8"
                                         IsReadOnly="True"
                                         Text="{Binding AudioProjectPath, Mode=OneWay}" />
                                <Button Grid.Row="0"
                                        Grid.Column="2"
                                        Padding="12,6"
                                        Margin="0,0,8,8"
                                        Command="{Binding CreateAudioProjectCommand}"
                                        Content="创建项目" />
                                <Button Grid.Row="0"
                                        Grid.Column="3"
                                        Padding="12,6"
                                        Margin="0,0,8,8"
                                        Style="{StaticResource GhostButtonStyle}"
                                        Command="{Binding LoadAudioProjectCommand}"
                                        Content="加载项目" />
                                <Button Grid.Row="0"
                                        Grid.Column="4"
                                        Padding="12,6"
                                        Margin="0,0,0,8"
                                        Style="{StaticResource GhostButtonStyle}"
                                        Command="{Binding OpenAudioProjectDirectoryCommand}"
                                        Content="打开项目目录" />

                                <TextBlock Grid.Row="1"
                                           Grid.Column="0"
                                           VerticalAlignment="Center"
                                           Text="项目状态" />
                                <TextBlock Grid.Row="1"
                                           Grid.Column="1"
                                           Grid.ColumnSpan="4"
                                           Margin="8,0,0,8"
                                           Foreground="{StaticResource AccentBrushDark}"
                                           Text="{Binding AudioProjectStatusSummary}"
                                           TextWrapping="Wrap" />

                                <TextBlock Grid.Row="2"
                                           Grid.Column="0"
                                           VerticalAlignment="Center"
                                           Text="工作音频" />
                                <TextBox Grid.Row="2"
                                         Grid.Column="1"
                                         Margin="8,0,8,8"
                                         IsReadOnly="True"
                                         Text="{Binding AudioProjectWorkingAudioPath, Mode=OneWay}" />
                                <Button Grid.Row="2"
                                        Grid.Column="2"
                                        Padding="12,6"
                                        Margin="0,0,0,8"
                                        Command="{Binding ExportAudioWorkCommand}"
                                        Content="导出工作音频" />

                                <TextBlock Grid.Row="3"
                                           Grid.Column="0"
                                           VerticalAlignment="Center"
                                           Text="Transcript" />
                                <TextBox Grid.Row="3"
                                         Grid.Column="1"
                                         Margin="8,0,8,8"
                                         IsReadOnly="True"
                                         Text="{Binding AudioProjectTranscriptPath, Mode=OneWay}" />
                                <Button Grid.Row="3"
                                        Grid.Column="2"
                                        Padding="12,6"
                                        Margin="0,0,0,8"
                                        Command="{Binding ImportAudioTranscriptCommand}"
                                        Content="导入 Transcript" />

                                <TextBlock Grid.Row="4"
                                           Grid.Column="0"
                                           VerticalAlignment="Center"
                                           Text="Selection" />
                                <TextBox Grid.Row="4"
                                         Grid.Column="1"
                                         Margin="8,0,8,0"
                                         IsReadOnly="True"
                                         Text="{Binding AudioProjectSelectionPath, Mode=OneWay}" />
                                <StackPanel Grid.Row="4"
                                            Grid.Column="2"
                                            Grid.ColumnSpan="3"
                                            Orientation="Horizontal">
                                    <Button Padding="12,6"
                                            Margin="0,0,8,0"
                                            Command="{Binding ImportAudioSelectionCommand}"
                                            Content="导入 Selection" />
                                    <ComboBox Width="140"
                                              Margin="0,0,8,0"
                                              SelectedValue="{Binding SelectedAudioRenderMode}"
                                              SelectedValuePath="Tag">
                                        <ComboBoxItem Tag="{x:Static model:AudioRenderMode.PreserveTimeline}">保留时间线</ComboBoxItem>
                                        <ComboBoxItem Tag="{x:Static model:AudioRenderMode.Concat}">拼接输出</ComboBoxItem>
                                    </ComboBox>
                                    <Button Padding="12,6"
                                            Command="{Binding RenderAudioSelectionCommand}"
                                            Content="按选择结果渲染" />
                                </StackPanel>
                            </Grid>
                        </GroupBox>

                        <GroupBox Grid.Row="2"
                                  Margin="0,14,0,0"
                                  Header="提取参数">
                            <Grid Margin="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           VerticalAlignment="Center"
                                           Text="输出格式" />
                                <ComboBox Grid.Row="0"
                                          Grid.Column="1"
                                          Margin="8,0,16,8"
                                          SelectedValue="{Binding SelectedAudioFormat}"
                                          SelectedValuePath="Tag">
                                    <ComboBoxItem Tag="{x:Static model:AudioFormat.AAC}">AAC (.m4a)</ComboBoxItem>
                                    <ComboBoxItem Tag="{x:Static model:AudioFormat.MP3}">MP3 (.mp3)</ComboBoxItem>
                                    <ComboBoxItem Tag="{x:Static model:AudioFormat.WAV}">WAV (.wav)</ComboBoxItem>
                                    <ComboBoxItem Tag="{x:Static model:AudioFormat.FLAC}">FLAC (.flac)</ComboBoxItem>
                                    <ComboBoxItem Tag="{x:Static model:AudioFormat.Copy}">直拷 (原格式)</ComboBoxItem>
                                </ComboBox>

                                <TextBlock Grid.Row="0"
                                           Grid.Column="2"
                                           VerticalAlignment="Center"
                                           Text="音轨选择" />
                                <ComboBox Grid.Row="0"
                                          Grid.Column="3"
                                          Margin="8,0,0,8"
                                          DisplayMemberPath="Summary"
                                          ItemsSource="{Binding AudioTracks}"
                                          SelectedItem="{Binding SelectedAudioTrack}" />

                                <TextBlock Grid.Row="1"
                                           Grid.Column="0"
                                           VerticalAlignment="Center"
                                           Text="开始时间" />
                                <TextBox Grid.Row="1"
                                         Grid.Column="1"
                                         Margin="8,0,16,8"
                                         Text="{Binding AudioStartTimeText, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Row="1"
                                           Grid.Column="2"
                                           VerticalAlignment="Center"
                                           Text="截取时长" />
                                <TextBox Grid.Row="1"
                                         Grid.Column="3"
                                         Margin="8,0,0,8"
                                         Text="{Binding AudioDurationText, UpdateSourceTrigger=PropertyChanged}" />

                                <StackPanel Grid.Row="2"
                                            Grid.Column="1"
                                            Grid.ColumnSpan="3"
                                            Orientation="Horizontal">
                                    <CheckBox Margin="0,0,16,0"
                                              IsChecked="{Binding AudioNormalize}"
                                              Content="响度标准化 (-14 LUFS)" />
                                    <TextBlock Margin="0,2,16,0"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource MutedBrush}"
                                               Text="{Binding AudioSourceDurationText, StringFormat=媒体时长：{0}}" />
                                    <Button Command="{Binding ExtractAudioCommand}"
                                            Content="开始提取" />
                                    <Button Command="{Binding CancelAudioExtractionCommand}"
                                            Content="取消提取" />
                                    <Button Margin="0"
                                            Style="{StaticResource GhostButtonStyle}"
                                            Command="{Binding OpenAudioOutputDirectoryCommand}"
                                            Content="打开音频目录" />
                                </StackPanel>
                            </Grid>
                        </GroupBox>

                        <GroupBox Grid.Row="3"
                                  Margin="0,14,0,0"
                                  Header="BGM 混音">
                            <Grid Margin="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           VerticalAlignment="Center"
                                           Text="BGM 文件" />
                                <TextBox Grid.Row="0"
                                         Grid.Column="1"
                                         Margin="8,0,8,8"
                                         IsReadOnly="True"
                                         Text="{Binding AudioMixBackgroundPath, Mode=OneWay}" />
                                <Button Grid.Row="0"
                                        Grid.Column="2"
                                        Padding="12,6"
                                        Margin="0,0,8,8"
                                        Command="{Binding ChooseAudioMixBackgroundCommand}"
                                        Content="选择 BGM" />
                                <Button Grid.Row="0"
                                        Grid.Column="3"
                                        Padding="12,6"
                                        Margin="0,0,0,8"
                                        Style="{StaticResource GhostButtonStyle}"
                                        Command="{Binding ClearAudioMixBackgroundCommand}"
                                        Content="清空" />

                                <TextBlock Grid.Row="1"
                                           Grid.Column="0"
                                           VerticalAlignment="Center"
                                           Text="主音量" />
                                <TextBox Grid.Row="1"
                                         Grid.Column="1"
                                         Margin="8,0,16,8"
                                         Text="{Binding AudioMixSourceVolumeText, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Row="1"
                                           Grid.Column="2"
                                           VerticalAlignment="Center"
                                           Text="BGM 音量" />
                                <TextBox Grid.Row="1"
                                         Grid.Column="3"
                                         Margin="8,0,0,8"
                                         Text="{Binding AudioMixBackgroundVolumeText, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Row="2"
                                           Grid.Column="0"
                                           VerticalAlignment="Center"
                                           Text="混音输出" />
                                <TextBox Grid.Row="2"
                                         Grid.Column="1"
                                         Grid.ColumnSpan="3"
                                         Margin="8,0,0,8"
                                         IsReadOnly="True"
                                         Text="{Binding AudioMixOutputPathPreview, Mode=OneWay}" />

                                <DockPanel Grid.Row="3"
                                           Grid.Column="1"
                                           Grid.ColumnSpan="3">
                                    <TextBlock DockPanel.Dock="Left"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource MutedBrush}"
                                               Text="混音会复用当前选中音轨、开始时间、时长和响度标准化设置。" />
                                    <StackPanel DockPanel.Dock="Right"
                                                Orientation="Horizontal">
                                        <Button Margin="0"
                                                Command="{Binding StartAudioMixCommand}"
                                                Content="开始混音" />
                                        <Button Margin="0"
                                                Style="{StaticResource GhostButtonStyle}"
                                                Command="{Binding OpenAudioMixOutputDirectoryCommand}"
                                                Content="打开混音目录" />
                                    </StackPanel>
                                </DockPanel>
                            </Grid>
                        </GroupBox>

                        <Border Grid.Row="4"
                                Margin="0,14,0,0"
                                Padding="16"
                                Background="#FFF8EE"
                                BorderBrush="#DDCDB9"
                                BorderThickness="1"
                                CornerRadius="14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock FontSize="16"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource InkBrush}"
                                               Text="{Binding AudioInputFileName}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Foreground="{StaticResource AccentBrushDark}"
                                               Text="{Binding AudioStatusMessage}" />
                                    <TextBlock Margin="0,6,0,10"
                                               Foreground="{StaticResource MutedBrush}"
                                               Text="时间支持 hh:mm:ss[.fff] 或纯秒数；留空表示整段输出。" />
                                    <Grid>
                                        <ProgressBar Height="18"
                                                     Minimum="0"
                                                     Maximum="100"
                                                     Value="{Binding AudioProgress, Mode=OneWay}"
                                                     Foreground="{StaticResource AccentBrush}"
                                                     Background="#E8DDD0" />
                                        <TextBlock HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource InkBrush}"
                                                   Text="{Binding AudioProgressText}" />
                                    </Grid>
                                </StackPanel>

                                <StackPanel Grid.Column="1"
                                            Margin="20,0,0,0"
                                            VerticalAlignment="Center">
                                    <TextBlock Foreground="{StaticResource MutedBrush}"
                                               Text="处理速度" />
                                    <TextBlock Margin="0,8,0,0"
                                               FontSize="24"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource InkBrush}"
                                               Text="{Binding AudioSpeedText}" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <GroupBox Grid.Row="5"
                                  Margin="0,14,0,0"
                                  Header="静音检测">
                            <Grid Margin="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           VerticalAlignment="Center"
                                           Text="静音阈值" />
                                <TextBox Grid.Row="0"
                                         Grid.Column="1"
                                         Margin="8,0,16,8"
                                         Text="{Binding AudioSilenceThresholdText, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Row="0"
                                           Grid.Column="2"
                                           VerticalAlignment="Center"
                                           Text="最短时长" />
                                <TextBox Grid.Row="0"
                                         Grid.Column="3"
                                         Margin="8,0,0,8"
                                         Text="{Binding AudioSilenceMinimumDurationText, UpdateSourceTrigger=PropertyChanged}" />

                                <DockPanel Grid.Row="1"
                                           Grid.Column="1"
                                           Grid.ColumnSpan="3">
                                    <TextBlock DockPanel.Dock="Left"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource AccentBrushDark}"
                                               Text="{Binding AudioSilenceSummary}" />
                                    <StackPanel DockPanel.Dock="Right"
                                                Orientation="Horizontal">
                                        <TextBlock Margin="0,2,16,0"
                                                   VerticalAlignment="Center"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   Text="示例：-30 dB，2 秒" />
                                        <Button Margin="0"
                                                Command="{Binding DetectSilenceCommand}"
                                                Content="分析静音区间" />
                                    </StackPanel>
                                </DockPanel>
                            </Grid>
                        </GroupBox>

                        <GroupBox Grid.Row="6"
                                  Margin="0,14,0,0"
                                  Header="音轨列表">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock Foreground="{StaticResource MutedBrush}"
                                           Text="上表选择要分析或提取的音轨；下表展示检测到的静音区间。" />

                                <DataGrid Grid.Row="1"
                                          Margin="0,8,0,10"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          IsReadOnly="True"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="Horizontal"
                                          RowBackground="#FFFDF8"
                                          AlternatingRowBackground="#FFF6EB"
                                          BorderThickness="0"
                                          ItemsSource="{Binding AudioTracks}"
                                          SelectedItem="{Binding SelectedAudioTrack}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Width="0.7*" Header="音轨" Binding="{Binding DisplayIndex}" />
                                        <DataGridTextColumn Width="0.9*" Header="语言" Binding="{Binding LanguageLabel}" />
                                        <DataGridTextColumn Width="0.9*" Header="编码" Binding="{Binding CodecName}" />
                                        <DataGridTextColumn Width="0.8*" Header="声道" Binding="{Binding Channels}" />
                                        <DataGridTextColumn Width="1*" Header="采样率" Binding="{Binding SampleRate}" />
                                        <DataGridTextColumn Width="0.8*" Header="码率" Binding="{Binding BitRateLabel}" />
                                        <DataGridCheckBoxColumn Width="0.8*" Header="默认" Binding="{Binding IsDefault}" />
                                        <DataGridTextColumn Width="2.8*" Header="摘要" Binding="{Binding Summary}" />
                                    </DataGrid.Columns>
                                </DataGrid>

                                <DataGrid Grid.Row="2"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          IsReadOnly="True"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="Horizontal"
                                          RowBackground="#FFFDF8"
                                          AlternatingRowBackground="#FFF6EB"
                                          BorderThickness="0"
                                          ItemsSource="{Binding SilenceSegments}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Width="1.2*" Header="开始" Binding="{Binding StartLabel}" />
                                        <DataGridTextColumn Width="1.2*" Header="结束" Binding="{Binding EndLabel}" />
                                        <DataGridTextColumn Width="1*" Header="时长" Binding="{Binding DurationLabel}" />
                                        <DataGridTextColumn Width="2.2*" Header="摘要" Binding="{Binding Summary}" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </GroupBox>
                    </Grid>
                </ScrollViewer>

                <!-- 视频裁剪模块 -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                              Padding="18"
                              Visibility="{Binding IsChecked, ElementName=NavClip, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <GroupBox Header="裁剪源">
                            <Grid Margin="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           VerticalAlignment="Center"
                                           Text="输入文件" />
                                <TextBox Grid.Row="0"
                                         Grid.Column="1"
                                         Margin="8,0,8,8"
                                         IsReadOnly="True"
                                         Text="{Binding ClipInputPath, Mode=OneWay}" />
                                <Button Grid.Row="0"
                                        Grid.Column="2"
                                        Padding="12,6"
                                        Margin="0,0,8,8"
                                        Command="{Binding ChooseClipInputCommand}"
                                        Content="选择媒体" />
                                <Button Grid.Row="0"
                                        Grid.Column="3"
                                        Padding="12,6"
                                        Margin="0,0,0,8"
                                        Style="{StaticResource GhostButtonStyle}"
                                        Command="{Binding UseSelectedJobAsClipInputCommand}"
                                        Content="带入选中任务" />

                                <TextBlock Grid.Row="1"
                                           Grid.Column="0"
                                           Margin="0,0,0,8"
                                           VerticalAlignment="Center"
                                           Text="输出位置" />
                                <TextBox Grid.Row="1"
                                         Grid.Column="1"
                                         Grid.ColumnSpan="3"
                                         Margin="8,0,0,8"
                                         IsReadOnly="True"
                                         Text="{Binding ClipOutputPathPreview, Mode=OneWay}" />

                                <StackPanel Grid.Row="2"
                                            Grid.Column="1"
                                            Grid.ColumnSpan="3">
                                    <TextBlock Foreground="{StaticResource AccentBrushDark}"
                                               Text="{Binding ClipProbeSummary}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Foreground="{StaticResource MutedBrush}"
                                               Text="{Binding ClipStatusMessage}" />
                                </StackPanel>
                            </Grid>
                        </GroupBox>

                        <GroupBox Grid.Row="1"
                                  Margin="0,14,0,0"
                                  Header="裁剪参数">
                            <Grid Margin="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           VerticalAlignment="Center"
                                           Text="裁剪模式" />
                                <ComboBox Grid.Row="0"
                                          Grid.Column="1"
                                          Margin="8,0,16,8"
                                          SelectedValue="{Binding SelectedClipMode}"
                                          SelectedValuePath="Tag">
                                    <ComboBoxItem Tag="{x:Static model:ClipMode.Fast}">无损快切</ComboBoxItem>
                                    <ComboBoxItem Tag="{x:Static model:ClipMode.Precise}">精准裁剪</ComboBoxItem>
                                </ComboBox>

                                <TextBlock Grid.Row="0"
                                           Grid.Column="2"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource MutedBrush}"
                                           Text="当前策略" />
                                <TextBlock Grid.Row="0"
                                           Grid.Column="3"
                                           Margin="8,0,0,8"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource AccentBrushDark}"
                                           Text="{Binding SelectedClipModeSummary}" />

                                <TextBlock Grid.Row="1"
                                           Grid.Column="0"
                                           VerticalAlignment="Center"
                                           Text="开始时间" />
                                <TextBox Grid.Row="1"
                                         Grid.Column="1"
                                         Margin="8,0,16,8"
                                         Text="{Binding ClipStartTimeText, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Row="1"
                                           Grid.Column="2"
                                           VerticalAlignment="Center"
                                           Text="截取时长" />
                                <TextBox Grid.Row="1"
                                         Grid.Column="3"
                                         Margin="8,0,0,8"
                                         Text="{Binding ClipDurationText, UpdateSourceTrigger=PropertyChanged}" />

                                <StackPanel Grid.Row="2"
                                            Grid.Column="1"
                                            Grid.ColumnSpan="3"
                                            Orientation="Horizontal">
                                    <TextBlock Margin="0,2,16,0"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource MutedBrush}"
                                               Text="{Binding ClipSourceDurationText, StringFormat=媒体时长：{0}}" />
                                    <TextBlock Margin="0,2,16,0"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource MutedBrush}"
                                               Text="时间支持 hh:mm:ss[.fff] 或纯秒数" />
                                    <Button Command="{Binding StartFastClipCommand}"
                                            Content="开始裁剪" />
                                    <Button Command="{Binding StartGifPreviewCommand}"
                                            Content="生成 GIF" />
                                    <Button Command="{Binding CancelClipCommand}"
                                            Content="取消裁剪" />
                                    <Button Margin="0"
                                            Style="{StaticResource GhostButtonStyle}"
                                            Command="{Binding OpenGifOutputDirectoryCommand}"
                                            Content="打开 GIF 目录" />
                                    <Button Margin="0"
                                            Style="{StaticResource GhostButtonStyle}"
                                            Command="{Binding OpenClipOutputDirectoryCommand}"
                                            Content="打开裁剪目录" />
                                </StackPanel>

                                <TextBlock Grid.Row="3"
                                           Grid.Column="0"
                                           VerticalAlignment="Center"
                                           Text="变速倍率" />
                                <TextBox Grid.Row="3"
                                         Grid.Column="1"
                                         Margin="8,0,16,0"
                                         Text="{Binding ClipSpeedFactorText, UpdateSourceTrigger=PropertyChanged}" />
                                <StackPanel Grid.Row="3"
                                            Grid.Column="2"
                                            Grid.ColumnSpan="2"
                                            Orientation="Horizontal">
                                    <TextBlock Margin="0,2,16,0"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource MutedBrush}"
                                               Text="支持 0.5x - 2.0x，倒放会复用当前开始时间和时长" />
                                    <Button Command="{Binding StartSpeedChangeCommand}"
                                            Content="生成变速" />
                                    <Button Command="{Binding StartReverseCommand}"
                                            Content="生成倒放" />
                                    <Button Margin="0"
                                            Style="{StaticResource GhostButtonStyle}"
                                            Command="{Binding OpenVideoFxOutputDirectoryCommand}"
                                            Content="打开特效目录" />
                                </StackPanel>
                            </Grid>
                        </GroupBox>

                        <Border Grid.Row="2"
                                Margin="0,14,0,0"
                                Padding="16"
                                Background="#FFF8EE"
                                BorderBrush="#DDCDB9"
                                BorderThickness="1"
                                CornerRadius="14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock FontSize="16"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource InkBrush}"
                                               Text="{Binding ClipInputFileName}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Foreground="{StaticResource AccentBrushDark}"
                                               Text="{Binding ClipStatusMessage}" />
                                    <TextBlock Margin="0,6,0,10"
                                               Foreground="{StaticResource MutedBrush}"
                                               Text="快切速度更快；精切会重编码并尽量按精确时间切出片段。" />
                                    <Grid>
                                        <ProgressBar Height="18"
                                                     Minimum="0"
                                                     Maximum="100"
                                                     Value="{Binding ClipProgress, Mode=OneWay}"
                                                     Foreground="{StaticResource AccentBrush}"
                                                     Background="#E8DDD0" />
                                        <TextBlock HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource InkBrush}"
                                                   Text="{Binding ClipProgressText}" />
                                    </Grid>
                                </StackPanel>

                                <StackPanel Grid.Column="1"
                                            Margin="20,0,0,0"
                                            VerticalAlignment="Center">
                                    <TextBlock Foreground="{StaticResource MutedBrush}"
                                               Text="处理速度" />
                                    <TextBlock Margin="0,8,0,0"
                                               FontSize="24"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource InkBrush}"
                                               Text="{Binding ClipSpeedText}" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <GroupBox Grid.Row="3"
                                  Margin="0,14,0,0"
                                  Header="竖屏适配">
                            <Grid Margin="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           VerticalAlignment="Center"
                                           Text="适配模式" />
                                <ComboBox Grid.Row="0"
                                          Grid.Column="1"
                                          Margin="8,0,16,8"
                                          SelectedValue="{Binding SelectedVerticalMode}"
                                          SelectedValuePath="Tag">
                                    <ComboBoxItem Tag="{x:Static model:VerticalMode.BlurBackground}">模糊背景</ComboBoxItem>
                                    <ComboBoxItem Tag="{x:Static model:VerticalMode.CropCenter}">中心裁切</ComboBoxItem>
                                </ComboBox>

                                <TextBlock Grid.Row="0"
                                           Grid.Column="2"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource MutedBrush}"
                                           Text="输出路径" />
                                <TextBlock Grid.Row="0"
                                           Grid.Column="3"
                                           Margin="8,0,0,8"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource AccentBrushDark}"
                                           Text="{Binding VerticalOutputPathPreview}" />

                                <StackPanel Grid.Row="1"
                                            Grid.Column="1"
                                            Grid.ColumnSpan="3"
                                            Orientation="Horizontal">
                                    <TextBlock Margin="0,2,16,0"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource MutedBrush}"
                                               Text="输出固定为 1080x1920 MP4" />
                                    <Button Command="{Binding StartVerticalAdaptCommand}"
                                            Content="开始竖屏适配" />
                                    <Button Margin="0"
                                            Style="{StaticResource GhostButtonStyle}"
                                            Command="{Binding OpenVerticalOutputDirectoryCommand}"
                                            Content="打开竖屏目录" />
                                </StackPanel>
                            </Grid>
                        </GroupBox>

                        <GroupBox Grid.Row="4"
                                  Margin="0,14,0,0"
                                  Header="画中画">
                            <Grid Margin="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           VerticalAlignment="Center"
                                           Text="叠加素材" />
                                <TextBox Grid.Row="0"
                                         Grid.Column="1"
                                         Margin="8,0,16,8"
                                         IsReadOnly="True"
                                         Text="{Binding PipOverlayPath, Mode=OneWay}" />
                                <Button Grid.Row="0"
                                        Grid.Column="2"
                                        Padding="12,6"
                                        Margin="0,0,8,8"
                                        Command="{Binding ChoosePipOverlayCommand}"
                                        Content="选择素材" />
                                <Button Grid.Row="0"
                                        Grid.Column="3"
                                        Padding="12,6"
                                        Margin="0,0,0,8"
                                        Style="{StaticResource GhostButtonStyle}"
                                        Command="{Binding ClearPipOverlayCommand}"
                                        Content="清空" />

                                <TextBlock Grid.Row="1"
                                           Grid.Column="0"
                                           VerticalAlignment="Center"
                                           Text="位置" />
                                <ComboBox Grid.Row="1"
                                          Grid.Column="1"
                                          Margin="8,0,16,8"
                                          SelectedValue="{Binding SelectedPipCorner}"
                                          SelectedValuePath="Tag">
                                    <ComboBoxItem Tag="{x:Static model:PipCorner.TopLeft}">左上</ComboBoxItem>
                                    <ComboBoxItem Tag="{x:Static model:PipCorner.TopRight}">右上</ComboBoxItem>
                                    <ComboBoxItem Tag="{x:Static model:PipCorner.BottomLeft}">左下</ComboBoxItem>
                                    <ComboBoxItem Tag="{x:Static model:PipCorner.BottomRight}">右下</ComboBoxItem>
                                </ComboBox>

                                <TextBlock Grid.Row="1"
                                           Grid.Column="2"
                                           VerticalAlignment="Center"
                                           Text="缩放比例" />
                                <TextBox Grid.Row="1"
                                         Grid.Column="3"
                                         Margin="8,0,0,8"
                                         Text="{Binding PipScaleText, UpdateSourceTrigger=PropertyChanged}" />

                                <DockPanel Grid.Row="2"
                                           Grid.Column="1"
                                           Grid.ColumnSpan="3">
                                    <StackPanel DockPanel.Dock="Left">
                                        <TextBlock Foreground="{StaticResource AccentBrushDark}"
                                                   Text="{Binding PipOutputPathPreview}" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   Text="首版保留主视频音轨，不混入小窗音频；缩放建议 0.20 到 0.35。" />
                                    </StackPanel>
                                    <StackPanel DockPanel.Dock="Right"
                                                Orientation="Horizontal">
                                        <Button Command="{Binding StartPictureInPictureCommand}"
                                                Content="生成画中画" />
                                        <Button Style="{StaticResource GhostButtonStyle}"
                                                Command="{Binding OpenPipOutputDirectoryCommand}"
                                                Content="打开画中画目录" />
                                    </StackPanel>
                                </DockPanel>
                            </Grid>
                        </GroupBox>

                        <GroupBox Grid.Row="5"
                                  Margin="0,14,0,0"
                                  Header="片段拼接">
                            <Grid Margin="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.3*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           Foreground="{StaticResource MutedBrush}"
                                           Text="每行一个片段，格式：开始时间,时长。支持 hh:mm:ss[.fff] 或纯秒数。" />

                                <TextBox Grid.Row="1"
                                         Grid.Column="0"
                                         Margin="0,10,0,0"
                                         MinHeight="132"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         Text="{Binding ConcatSegmentsText, UpdateSourceTrigger=PropertyChanged}" />

                                <StackPanel Grid.Row="2"
                                            Grid.Column="0"
                                            Margin="0,10,0,0">
                                    <TextBlock Foreground="{StaticResource AccentBrushDark}"
                                               Text="{Binding ConcatSummary}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Foreground="{StaticResource MutedBrush}"
                                               Text="{Binding ConcatOutputPathPreview}" />
                                    <StackPanel Margin="0,10,0,0"
                                                Orientation="Horizontal">
                                        <Button Command="{Binding StartConcatCommand}"
                                                Content="开始拼接" />
                                        <Button Style="{StaticResource GhostButtonStyle}"
                                                Command="{Binding OpenConcatOutputDirectoryCommand}"
                                                Content="打开拼接目录" />
                                    </StackPanel>
                                </StackPanel>

                                <Border Grid.Row="0"
                                        Grid.RowSpan="3"
                                        Grid.Column="2"
                                        Background="#FFFDF8"
                                        BorderBrush="#E0D1BE"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="10">
                                    <DataGrid ItemsSource="{Binding ConcatSegments}"
                                              AutoGenerateColumns="False"
                                              HeadersVisibility="Column"
                                              CanUserAddRows="False"
                                              CanUserDeleteRows="False"
                                              IsReadOnly="True"
                                              MinHeight="220"
                                              RowHeaderWidth="0"
                                              GridLinesVisibility="Horizontal">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Width="60"
                                                                Header="#"
                                                                Binding="{Binding Sequence}" />
                                            <DataGridTextColumn Width="*"
                                                                Header="开始"
                                                                Binding="{Binding StartText}" />
                                            <DataGridTextColumn Width="*"
                                                                Header="时长"
                                                                Binding="{Binding DurationText}" />
                                            <DataGridTextColumn Width="*"
                                                                Header="结束"
                                                                Binding="{Binding EndText}" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Border>
                            </Grid>
                        </GroupBox>

                        <GroupBox Grid.Row="6"
                                  Margin="0,14,0,0"
                                  Header="场景检测">
                            <Grid Margin="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           VerticalAlignment="Center"
                                           Text="检测阈值" />
                                <TextBox Grid.Row="0"
                                         Grid.Column="1"
                                         Margin="8,0,0,8"
                                         Text="{Binding SceneDetectionThresholdText, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Grid.Row="0"
                                           Grid.Column="2"
                                           Margin="16,0,0,0"
                                           VerticalAlignment="Center"
                                           Text="最短片段" />
                                <TextBox Grid.Row="0"
                                         Grid.Column="3"
                                         Margin="8,0,0,8"
                                         Text="{Binding AutoSegmentMinimumDurationText, UpdateSourceTrigger=PropertyChanged}" />
                                <StackPanel Grid.Row="0"
                                            Grid.Column="4"
                                            Margin="12,0,0,8"
                                            Orientation="Horizontal">
                                    <Button Command="{Binding DetectScenesCommand}"
                                            Content="开始检测" />
                                    <Button Margin="0"
                                            Command="{Binding CancelClipCommand}"
                                            Content="取消检测" />
                                </StackPanel>

                                <StackPanel Grid.Row="1"
                                            Grid.Column="0"
                                            Grid.ColumnSpan="5">
                                    <TextBlock Foreground="{StaticResource AccentBrushDark}"
                                               Text="{Binding SceneDetectionSummary}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Foreground="{StaticResource MutedBrush}"
                                               Text="建议先从 0.20 到 0.35 试起；阈值越低，切点越多。" />
                                </StackPanel>

                                <Grid Grid.Row="2"
                                      Grid.Column="0"
                                      Grid.ColumnSpan="5"
                                      Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               VerticalAlignment="Center"
                                               Text="最大片段" />
                                    <TextBox Grid.Column="1"
                                             Margin="8,0,16,0"
                                             Text="{Binding AutoSegmentMaximumDurationText, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Grid.Column="2"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource AccentBrushDark}"
                                               Text="{Binding AutoSegmentSummary}" />
                                    <Button Grid.Column="3"
                                            Command="{Binding GenerateAutoSegmentsCommand}"
                                            Content="生成自动分段" />
                                </Grid>

                                <Border Grid.Row="0"
                                        Grid.RowSpan="3"
                                        Grid.Column="6"
                                        Background="#FFFDF8"
                                        BorderBrush="#E0D1BE"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="10">
                                    <DataGrid ItemsSource="{Binding SceneCutPoints}"
                                              AutoGenerateColumns="False"
                                              HeadersVisibility="Column"
                                              CanUserAddRows="False"
                                              CanUserDeleteRows="False"
                                              IsReadOnly="True"
                                              MinHeight="150"
                                              RowHeaderWidth="0"
                                              GridLinesVisibility="Horizontal">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Width="60"
                                                                Header="#"
                                                                Binding="{Binding Sequence}" />
                                            <DataGridTextColumn Width="*"
                                                                Header="切点时间"
                                                                Binding="{Binding TimeText}" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Border>
                            </Grid>
                        </GroupBox>

                        <GroupBox Grid.Row="7"
                                  Margin="0,14,0,0"
                                  Header="封面候选">
                            <Grid Margin="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="280" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0"
                                            Grid.Column="0"
                                            Grid.RowSpan="2">
                                    <TextBlock Foreground="{StaticResource AccentBrushDark}"
                                               Text="{Binding CoverCandidatesSummary}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Foreground="{StaticResource MutedBrush}"
                                               Text="{Binding CoverCandidatesDirectory}" />
                                    <StackPanel Margin="0,10,0,0"
                                                Orientation="Horizontal">
                                        <Button Command="{Binding GenerateCoverCandidatesCommand}"
                                                Content="生成候选" />
                                        <Button Style="{StaticResource GhostButtonStyle}"
                                                Command="{Binding OpenCoverCandidatesDirectoryCommand}"
                                                Content="打开目录" />
                                    </StackPanel>
                                    <TextBlock Margin="0,10,0,0"
                                               Foreground="{StaticResource MutedBrush}"
                                               Text="会优先挑选对比度更高、曝光更稳的画面；结果可直接点击打开原图。" />
                                </StackPanel>

                                <Border Grid.Row="0"
                                        Grid.RowSpan="2"
                                        Grid.Column="2"
                                        Background="#FFFDF8"
                                        BorderBrush="#E0D1BE"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="10">
                                    <DataGrid ItemsSource="{Binding CoverCandidates}"
                                              AutoGenerateColumns="False"
                                              HeadersVisibility="Column"
                                              CanUserAddRows="False"
                                              CanUserDeleteRows="False"
                                              IsReadOnly="True"
                                              MinHeight="180"
                                              RowHeaderWidth="0"
                                              GridLinesVisibility="Horizontal">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Width="0.9*"
                                                                Header="时间"
                                                                Binding="{Binding TimeLabel}" />
                                            <DataGridTextColumn Width="0.9*"
                                                                Header="状态"
                                                                Binding="{Binding InspectionSeverity}" />
                                            <DataGridTextColumn Width="1*"
                                                                Header="亮度"
                                                                Binding="{Binding AverageLumaLabel}" />
                                            <DataGridTextColumn Width="1*"
                                                                Header="对比度"
                                                                Binding="{Binding ContrastLabel}" />
                                            <DataGridTemplateColumn Width="0.8*"
                                                                    Header="打开">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Button Padding="8,4"
                                                                Margin="0"
                                                                Style="{StaticResource GhostButtonStyle}"
                                                                Command="{Binding DataContext.OpenInspectionSampleCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding OutputPath}"
                                                                Content="查看" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Border>
                            </Grid>
                        </GroupBox>

                        <GroupBox Grid.Row="8"
                                  Margin="0,14,0,0"
                                  Header="黑场 / 冻帧检测">
                            <Grid Margin="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Grid.Column="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="画面阈值" />
                                    <TextBox Grid.Column="1" Margin="8,0,8,8" Text="{Binding BlackDetectPictureThresholdText, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="像素阈值" />
                                    <TextBox Grid.Column="3" Margin="8,0,8,8" Text="{Binding BlackDetectPixelThresholdText, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Grid.Column="4" VerticalAlignment="Center" Text="最短时长" />
                                    <TextBox Grid.Column="5" Margin="8,0,8,8" Text="{Binding BlackDetectMinimumDurationText, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Column="6" Margin="0,0,0,8" Command="{Binding DetectBlackSegmentsCommand}" Content="分析黑场" />
                                </Grid>

                                <Grid Grid.Row="0" Grid.Column="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="噪声阈值" />
                                    <TextBox Grid.Column="1" Margin="8,0,8,8" Text="{Binding FreezeDetectNoiseThresholdText, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="最短时长" />
                                    <TextBox Grid.Column="3" Margin="8,0,8,8" Text="{Binding FreezeDetectMinimumDurationText, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Column="4" Margin="0,0,0,8" Command="{Binding DetectFreezeSegmentsCommand}" Content="分析冻帧" />
                                </Grid>

                                <Border Grid.Row="1"
                                        Grid.Column="0"
                                        Background="#FFFDF8"
                                        BorderBrush="#E0D1BE"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="10">
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource AccentBrushDark}"
                                                   Text="{Binding BlackDetectSummary}" />
                                        <DataGrid Margin="0,8,0,0"
                                                  ItemsSource="{Binding BlackSegments}"
                                                  AutoGenerateColumns="False"
                                                  HeadersVisibility="Column"
                                                  CanUserAddRows="False"
                                                  CanUserDeleteRows="False"
                                                  IsReadOnly="True"
                                                  MinHeight="150"
                                                  RowHeaderWidth="0"
                                                  GridLinesVisibility="Horizontal">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Width="*"
                                                                    Header="开始"
                                                                    Binding="{Binding StartLabel}" />
                                                <DataGridTextColumn Width="*"
                                                                    Header="结束"
                                                                    Binding="{Binding EndLabel}" />
                                                <DataGridTextColumn Width="*"
                                                                    Header="时长"
                                                                    Binding="{Binding DurationLabel}" />
                                                <DataGridTextColumn Width="1.8*"
                                                                    Header="摘要"
                                                                    Binding="{Binding Summary}" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="1"
                                        Grid.Column="2"
                                        Background="#FFFDF8"
                                        BorderBrush="#E0D1BE"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="10">
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource AccentBrushDark}"
                                                   Text="{Binding FreezeDetectSummary}" />
                                        <DataGrid Margin="0,8,0,0"
                                                  ItemsSource="{Binding FreezeSegments}"
                                                  AutoGenerateColumns="False"
                                                  HeadersVisibility="Column"
                                                  CanUserAddRows="False"
                                                  CanUserDeleteRows="False"
                                                  IsReadOnly="True"
                                                  MinHeight="150"
                                                  RowHeaderWidth="0"
                                                  GridLinesVisibility="Horizontal">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Width="*"
                                                                    Header="开始"
                                                                    Binding="{Binding StartLabel}" />
                                                <DataGridTextColumn Width="*"
                                                                    Header="结束"
                                                                    Binding="{Binding EndLabel}" />
                                                <DataGridTextColumn Width="*"
                                                                    Header="时长"
                                                                    Binding="{Binding DurationLabel}" />
                                                <DataGridTextColumn Width="1.8*"
                                                                    Header="摘要"
                                                                    Binding="{Binding Summary}" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </GroupBox>

                        <GroupBox Grid.Row="9"
                                  Margin="0,14,0,0"
                                  Header="输出说明">
                            <StackPanel Margin="12">
                                <TextBlock Foreground="{StaticResource MutedBrush}"
                                           Text="输出目录固定为 OutputDirectory\\video_clips；未开启覆盖时会自动追加序号避免覆盖。" />
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="{StaticResource MutedBrush}"
                                           Text="无损快切使用 -c copy，速度快，但起点通常会受关键帧位置影响；精准裁剪会重编码视频和音频。" />
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="{StaticResource MutedBrush}"
                                           Text="片段拼接首版仅支持同一输入文件内多片段顺序拼接，会重编码视频并使用主音轨；字幕不会保留。" />
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="{StaticResource MutedBrush}"
                                           Text="场景检测会返回候选切点时间，不会直接导出截图；可把时间点复制回裁剪或拼接输入。" />
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="{StaticResource MutedBrush}"
                                           Text="封面候选会基于切点自动抽帧并按画面对比度/曝光稳定性排序，方便直接挑封面。" />
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="{StaticResource MutedBrush}"
                                           Text="黑场检测适合找片头片尾纯黑段；冻帧检测适合找静止字幕卡或停格镜头。" />
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="{StaticResource MutedBrush}"
                                           Text="{Binding GifOutputPathPreview}" />
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="{StaticResource MutedBrush}"
                                           Text="GIF 预览会复用当前开始时间和时长，输出到 OutputDirectory\\video_gifs。" />
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="{StaticResource MutedBrush}"
                                           Text="{Binding PipOutputPathPreview}" />
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="{StaticResource MutedBrush}"
                                           Text="画中画首版保留主视频音轨，输出到 OutputDirectory\\video_pip。" />
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="{StaticResource MutedBrush}"
                                           Text="{Binding SpeedOutputPathPreview}" />
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="{StaticResource MutedBrush}"
                                           Text="{Binding ReverseOutputPathPreview}" />
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="{StaticResource MutedBrush}"
                                           Text="变速与倒放会重编码为 MP4，输出到 OutputDirectory\\video_fx。" />
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="{StaticResource MutedBrush}"
                                           Text="如需打开 GIF 目录，可在生成后使用单独目录按钮。" />
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="{StaticResource MutedBrush}"
                                           Text="{Binding GifOutputDirectoryPath}" />
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="{StaticResource MutedBrush}"
                                           Text="{Binding PipOutputDirectoryPath}" />
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="{StaticResource MutedBrush}"
                                           Text="{Binding VideoFxOutputDirectoryPath}" />
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="{StaticResource MutedBrush}"
                                           Text="竖屏适配输出目录固定为 OutputDirectory\\video_vertical，支持模糊背景和中心裁切两种模式。" />
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="{StaticResource AccentBrushDark}"
                                           Text="{Binding ClipOutputPathPreview}" />
                            </StackPanel>
                        </GroupBox>
                    </Grid>
                </ScrollViewer>

                <!-- 抖音直出模块 -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                              Padding="18"
                              Visibility="{Binding IsChecked, ElementName=NavDouyin, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <GroupBox Header="直出源">
                            <Grid Margin="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           VerticalAlignment="Center"
                                           Text="输入文件" />
                                <TextBox Grid.Row="0"
                                         Grid.Column="1"
                                         Margin="8,0,8,8"
                                         IsReadOnly="True"
                                         Text="{Binding ClipInputPath, Mode=OneWay}" />
                                <Button Grid.Row="0"
                                        Grid.Column="2"
                                        Padding="12,6"
                                        Margin="0,0,8,8"
                                        Command="{Binding ChooseClipInputCommand}"
                                        Content="选择媒体" />
                                <Button Grid.Row="0"
                                        Grid.Column="3"
                                        Padding="12,6"
                                        Margin="0,0,0,8"
                                        Style="{StaticResource GhostButtonStyle}"
                                        Command="{Binding UseSelectedJobAsClipInputCommand}"
                                        Content="带入选中任务" />

                                <TextBlock Grid.Row="1"
                                           Grid.Column="0"
                                           VerticalAlignment="Center"
                                           Text="BGM" />
                                <TextBox Grid.Row="1"
                                         Grid.Column="1"
                                         Margin="8,0,8,8"
                                         IsReadOnly="True"
                                         Text="{Binding DouyinBgmPath, Mode=OneWay}" />
                                <Button Grid.Row="1"
                                        Grid.Column="2"
                                        Padding="12,6"
                                        Margin="0,0,8,8"
                                        Command="{Binding ChooseDouyinBgmCommand}"
                                        Content="选择 BGM" />
                                <Button Grid.Row="1"
                                        Grid.Column="3"
                                        Padding="12,6"
                                        Margin="0,0,0,8"
                                        Style="{StaticResource GhostButtonStyle}"
                                        Command="{Binding ClearDouyinBgmCommand}"
                                        Content="清空 BGM" />

                                <StackPanel Grid.Row="2"
                                            Grid.Column="1"
                                            Grid.ColumnSpan="3">
                                    <TextBlock Foreground="{StaticResource AccentBrushDark}"
                                               Text="{Binding ClipProbeSummary}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Foreground="{StaticResource MutedBrush}"
                                               Text="{Binding DouyinStatusMessage}" />
                                </StackPanel>
                            </Grid>
                        </GroupBox>

                        <GroupBox Grid.Row="1"
                                  Margin="0,14,0,0"
                                  Header="模板参数">
                            <Grid Margin="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           VerticalAlignment="Center"
                                           Text="模板预设" />
                                <ComboBox Grid.Row="0"
                                          Grid.Column="1"
                                          Margin="8,0,16,8"
                                          SelectedValue="{Binding SelectedDouyinTemplatePreset}"
                                          SelectedValuePath="Tag">
                                    <ComboBoxItem Tag="{x:Static model:DouyinTemplatePreset.BlurTitleWatermark}">模糊背景 + 标题水印</ComboBoxItem>
                                    <ComboBoxItem Tag="{x:Static model:DouyinTemplatePreset.CropTitleWatermark}">中心裁切 + 标题水印</ComboBoxItem>
                                    <ComboBoxItem Tag="{x:Static model:DouyinTemplatePreset.BlurBgmBoost}">模糊背景 + BGM 增强</ComboBoxItem>
                                </ComboBox>

                                <TextBlock Grid.Row="0"
                                           Grid.Column="2"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource MutedBrush}"
                                           Text="输出策略" />
                                <TextBlock Grid.Row="0"
                                           Grid.Column="3"
                                           Margin="8,0,0,8"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource AccentBrushDark}"
                                           Text="{Binding SelectedDouyinTemplateSummary}" />

                                <TextBlock Grid.Row="1"
                                           Grid.Column="0"
                                           VerticalAlignment="Center"
                                           Text="标题文字" />
                                <TextBox Grid.Row="1"
                                         Grid.Column="1"
                                         Margin="8,0,16,8"
                                         Text="{Binding DouyinTitleText, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Row="1"
                                           Grid.Column="2"
                                           VerticalAlignment="Center"
                                           Text="水印文字" />
                                <TextBox Grid.Row="1"
                                         Grid.Column="3"
                                         Margin="8,0,0,8"
                                         Text="{Binding DouyinWatermarkText, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Row="2"
                                           Grid.Column="0"
                                           VerticalAlignment="Center"
                                           Text="原声音量" />
                                <TextBox Grid.Row="2"
                                         Grid.Column="1"
                                         Margin="8,0,16,0"
                                         Text="{Binding DouyinSourceVolumeText, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Row="2"
                                           Grid.Column="2"
                                           VerticalAlignment="Center"
                                           Text="BGM 音量" />
                                <TextBox Grid.Row="2"
                                         Grid.Column="3"
                                         Margin="8,0,0,0"
                                         Text="{Binding DouyinBgmVolumeText, UpdateSourceTrigger=PropertyChanged}" />

                                <CheckBox Grid.Row="3"
                                          Grid.Column="1"
                                          Margin="8,10,16,0"
                                          IsChecked="{Binding DouyinBurnSubtitles}"
                                          Content="自动烧录最佳文本字幕" />
                                <TextBlock Grid.Row="3"
                                           Grid.Column="2"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource MutedBrush}"
                                           Text="字幕状态" />
                                <TextBlock Grid.Row="3"
                                           Grid.Column="3"
                                           Margin="8,10,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource AccentBrushDark}"
                                           Text="{Binding DouyinSubtitleSummary}" />
                            </Grid>
                        </GroupBox>

                        <Border Grid.Row="2"
                                Margin="0,14,0,0"
                                Padding="16"
                                Background="#FFF8EE"
                                BorderBrush="#DDCDB9"
                                BorderThickness="1"
                                CornerRadius="14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock FontSize="16"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource InkBrush}"
                                               Text="{Binding ClipInputFileName}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Foreground="{StaticResource AccentBrushDark}"
                                               Text="{Binding DouyinStatusMessage}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Foreground="{StaticResource MutedBrush}"
                                               Text="{Binding DouyinOutputPathPreview}" />
                                    <TextBlock Margin="0,6,0,10"
                                               Foreground="{StaticResource MutedBrush}"
                                               Text="输出固定为 1080x1920 MP4 / H.264 / AAC / 30fps / 44.1kHz，适合直接发短视频。" />
                                    <StackPanel Orientation="Horizontal">
                                        <Button Command="{Binding StartDouyinExportCommand}"
                                                Content="开始直出" />
                                        <Button Command="{Binding StartBatchDouyinExportCommand}"
                                                Content="批量直出队列" />
                                        <Button Command="{Binding CancelDouyinExportCommand}"
                                                Content="取消直出" />
                                        <Button Margin="0"
                                                Style="{StaticResource GhostButtonStyle}"
                                                Command="{Binding OpenDouyinOutputDirectoryCommand}"
                                                Content="打开输出目录" />
                                    </StackPanel>
                                    <Grid Margin="0,10,0,0">
                                        <ProgressBar Height="18"
                                                     Minimum="0"
                                                     Maximum="100"
                                                     Value="{Binding DouyinProgress, Mode=OneWay}"
                                                     Foreground="{StaticResource AccentBrush}"
                                                     Background="#E8DDD0" />
                                        <TextBlock HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource InkBrush}"
                                                   Text="{Binding DouyinProgressText}" />
                                    </Grid>
                                </StackPanel>

                                <StackPanel Grid.Column="1"
                                            Margin="20,0,0,0"
                                            VerticalAlignment="Center">
                                    <TextBlock Foreground="{StaticResource MutedBrush}"
                                               Text="处理速度" />
                                    <TextBlock Margin="0,8,0,0"
                                               FontSize="24"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource InkBrush}"
                                               Text="{Binding DouyinSpeedText}" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <GroupBox Grid.Row="3"
                                  Margin="0,14,0,0"
                                  Header="说明">
                            <StackPanel Margin="12">
                                <TextBlock Foreground="{StaticResource MutedBrush}"
                                           Text="当前首版专注单文件直出：竖屏适配、标题、水印、可选 BGM 混入。" />
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="{StaticResource MutedBrush}"
                                           Text="如果源文件没有音轨，必须选择 BGM；如果有原始音轨，BGM 可留空。" />
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="{StaticResource MutedBrush}"
                                           Text="当前支持自动选择并烧录最佳文本字幕；如果没有可用文本字幕，会自动回退为无字幕直出。" />
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="{StaticResource MutedBrush}"
                                           Text="当前批量直出会复用任务队列里的源文件，并统一套用当前模板参数、字幕策略和 BGM。" />
                            </StackPanel>
                        </GroupBox>
                    </Grid>
                </ScrollViewer>

                <!-- 任务历史模块 -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                              Padding="18"
                              Visibility="{Binding IsChecked, ElementName=NavHistory, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Margin="0,0,10,0" VerticalAlignment="Center" Text="状态筛选" />
                            <ComboBox Width="150"
                                      Margin="0,0,12,0"
                                      SelectedValue="{Binding HistoryStatusFilter}"
                                      SelectedValuePath="Tag">
                                <ComboBoxItem Tag="全部">全部</ComboBoxItem>
                                <ComboBoxItem Tag="等待中">等待中</ComboBoxItem>
                                <ComboBoxItem Tag="分析中">分析中</ComboBoxItem>
                                <ComboBoxItem Tag="转码中">转码中</ComboBoxItem>
                                <ComboBoxItem Tag="已完成">已完成</ComboBoxItem>
                                <ComboBoxItem Tag="失败">失败</ComboBoxItem>
                                <ComboBoxItem Tag="已跳过">已跳过</ComboBoxItem>
                                <ComboBoxItem Tag="已取消">已取消</ComboBoxItem>
                            </ComboBox>

                            <TextBlock Margin="0,0,10,0" VerticalAlignment="Center" Text="日期筛选" />
                            <DatePicker Width="170"
                                        Margin="0,0,12,0"
                                        SelectedDate="{Binding HistoryDateFilter}" />

                            <Button Style="{StaticResource GhostButtonStyle}"
                                    Command="{Binding ClearHistoryFiltersCommand}"
                                    Content="清空筛选" />
                        </StackPanel>

                        <DockPanel Grid.Row="1" Margin="0,12,0,12">
                            <TextBlock DockPanel.Dock="Left"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource AccentBrushDark}"
                                       Text="{Binding HistorySummary}" />
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <Button Style="{StaticResource GhostButtonStyle}"
                                        Command="{Binding ExportHistoryJsonCommand}"
                                        Content="导出 JSON" />
                                <Button Margin="0"
                                        Command="{Binding ExportHistoryTextCommand}"
                                        Content="导出 TXT" />
                            </StackPanel>
                        </DockPanel>

                        <DataGrid Grid.Row="2"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  RowBackground="#FFFDF8"
                                  AlternatingRowBackground="#FFF6EB"
                                  BorderThickness="0"
                                  ItemsSource="{Binding FilteredHistoryEntries}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Width="1.3*" Header="时间" Binding="{Binding RecordedAt, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" />
                                <DataGridTextColumn Width="1.8*" Header="文件名" Binding="{Binding FileName}" />
                                <DataGridTextColumn Width="*" Header="状态" Binding="{Binding StatusText}" />
                                <DataGridTextColumn Width="*" Header="字幕分析" Binding="{Binding SubtitleAnalysisSource}" />
                                <DataGridTextColumn Width="1.4*" Header="字幕类型" Binding="{Binding SubtitleKindSummary}" />
                                <DataGridTextColumn Width="*" Header="编码器" Binding="{Binding EncoderUsed}" />
                                <DataGridTextColumn Width="1.8*" Header="说明" Binding="{Binding Message}" />
                                <DataGridTextColumn Width="2.4*" Header="输出文件" Binding="{Binding OutputPath}" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </ScrollViewer>

                <!-- 巡检截图模块 -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                              Padding="18"
                              Visibility="{Binding IsChecked, ElementName=NavInspection, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <DockPanel Margin="8">
                        <StackPanel DockPanel.Dock="Top">
                            <DockPanel Margin="0,0,0,10">
                                <TextBlock DockPanel.Dock="Left"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource AccentBrushDark}"
                                           Text="{Binding InspectionSummary}" />
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <Button Style="{StaticResource GhostButtonStyle}"
                                            Command="{Binding ExportInspectionReportJsonCommand}"
                                            Content="导出 JSON 报告" />
                                    <Button Style="{StaticResource GhostButtonStyle}"
                                            Command="{Binding ExportInspectionReportTextCommand}"
                                            Content="导出 TXT 报告" />
                                    <Button Style="{StaticResource GhostButtonStyle}"
                                            Command="{Binding OpenInspectionDirectoryCommand}"
                                            Content="打开巡检目录" />
                                    <Button Margin="0"
                                            Command="{Binding CaptureSelectedFrameSetCommand}"
                                            Content="重新生成三连图" />
                                </StackPanel>
                            </DockPanel>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="78" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,8,6" Foreground="{StaticResource MutedBrush}" Text="来源" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Margin="0,0,0,6" Text="{Binding InspectionSource}" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,8,0" Foreground="{StaticResource MutedBrush}" Text="目录" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,0,0,6" Text="{Binding InspectionOutputDirectory}" TextWrapping="Wrap" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,8,0" Foreground="{StaticResource MutedBrush}" Text="结论" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding InspectionAttentionSummary}" TextWrapping="Wrap" />
                            </Grid>
                        </StackPanel>

                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding InspectionSamples}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="3" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,10,10" Padding="10" Background="#FFF8EE" BorderBrush="#DDCDB9" BorderThickness="1" CornerRadius="12">
                                            <StackPanel>
                                                <Border Height="110" Margin="0,0,0,10" Background="#EEE4D7" BorderBrush="#DAC7B1" BorderThickness="1" CornerRadius="10" ClipToBounds="True">
                                                    <Image Source="{Binding OutputPath}" Stretch="UniformToFill" />
                                                </Border>
                                                <TextBlock FontWeight="Bold" Foreground="{StaticResource InkBrush}" Text="{Binding TimeLabel}" />
                                                <Border Margin="0,8,0,0" Padding="8,4" CornerRadius="10">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#DCEEDF" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding InspectionSeverity}" Value="偏暗">
                                                                    <Setter Property="Background" Value="#F5D9D5" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding InspectionSeverity}" Value="偏亮">
                                                                    <Setter Property="Background" Value="#F5D9D5" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding InspectionSeverity}" Value="低对比度">
                                                                    <Setter Property="Background" Value="#F4DFC7" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding InspectionSeverity}" Value="需关注">
                                                                    <Setter Property="Background" Value="#F5D9D5" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding InspectionSeverity}" Value="缺失">
                                                                    <Setter Property="Background" Value="#E5DBD8" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock HorizontalAlignment="Center" Foreground="{StaticResource InkBrush}" FontWeight="SemiBold" Text="{Binding InspectionSeverity}" />
                                                </Border>
                                                <TextBlock Margin="0,6,0,0" FontSize="12" Foreground="{StaticResource MutedBrush}" Text="{Binding FileName}" TextWrapping="Wrap" />
                                                <TextBlock Margin="0,8,0,0" FontSize="12" Foreground="{StaticResource InkBrush}" Text="{Binding AverageLumaLabel}" />
                                                <TextBlock Margin="0,4,0,0" FontSize="12" Foreground="{StaticResource InkBrush}" Text="{Binding ContrastLabel}" />
                                                <TextBlock Margin="0,6,0,0" FontSize="12" Foreground="{StaticResource MutedBrush}" Text="{Binding InspectionNote}" TextWrapping="Wrap" />
                                                <Button Margin="0,10,0,0" Padding="10,6"
                                                        Command="{Binding DataContext.OpenInspectionSampleCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding OutputPath}"
                                                        Content="打开图片" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </ScrollViewer>

                <!-- 运行日志模块 -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                              Padding="18"
                              Visibility="{Binding IsChecked, ElementName=NavLog, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <DockPanel Margin="8">
                        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10" Orientation="Horizontal">
                            <TextBlock VerticalAlignment="Center"
                                       Foreground="{StaticResource MutedBrush}"
                                       Text="日志已同步写入 %APPDATA%\\AnimeTranscoder\\logs" />
                            <Button Margin="12,0,0,0"
                                    Style="{StaticResource GhostButtonStyle}"
                                    Command="{Binding OpenLogDirectoryCommand}"
                                    Content="打开日志目录" />
                        </StackPanel>
                        <TextBox Padding="10"
                                 FontFamily="Consolas"
                                 FontSize="13"
                                 Background="#FFFDF8"
                                 IsReadOnly="True"
                                 Text="{Binding LogText, Mode=OneWay}"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 AcceptsReturn="True" />
                    </DockPanel>
                </ScrollViewer>

            </Grid>
        </Grid>

        <StatusBar Grid.Row="2" Margin="0,4,0,0" Background="#F0E3D4">
            <StatusBarItem Content="{Binding StatusMessage}" />
        </StatusBar>

        <Border Grid.RowSpan="3"
                Panel.ZIndex="20"
                Background="#B8141B22"
                BorderBrush="#E9B15E"
                BorderThickness="4"
                CornerRadius="24"
                Visibility="{Binding IsDropTargetActive, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid Margin="24">
                <Border HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Padding="28,22"
                        Background="#F7F0E5"
                        BorderBrush="#A54E2B"
                        BorderThickness="2"
                        CornerRadius="18">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock HorizontalAlignment="Center"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="#7A3218"
                                   Text="松开即可加入队列" />
                        <TextBlock Margin="0,10,0,0"
                                   HorizontalAlignment="Center"
                                   Foreground="#5B4C42"
                                   Text="支持拖入 MKV 文件，或包含 MKV 的文件夹"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
